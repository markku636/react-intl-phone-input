{
  "name": "react-intl-phone-input",
  "version": "0.1.0",
  "description": "Framework-agnostic, antd-free international phone number input for React. E.164 in/out, searchable flag/country-code dropdown, configurable validation levels (strict / mobile-strict / loose), modern themeable CSS, i18n via a messages object or your own t() function. Phone logic powered by google-libphonenumber.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "react",
    "phone",
    "phone-input",
    "phone-number",
    "international",
    "e164",
    "libphonenumber",
    "google-libphonenumber",
    "intl-tel-input",
    "country-flag",
    "i18n",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --max-warnings=0",
    "fmt": "prettier --write .",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "google-libphonenumber": "^3.2.44",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "country-flag-icons": "1.6.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.5.2",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/node": "^20.11.0",
    "@types/react": "^17.0.83",
    "@types/react-dom": "^17.0.26",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "google-libphonenumber": "^3.2.44",
    "jsdom": "^24.0.0",
    "prettier": "^3.6.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.0",
    "typescript": "~5.1.6",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
